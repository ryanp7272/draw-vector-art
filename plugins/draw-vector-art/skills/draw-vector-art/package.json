{
  "name": "draw-vector-art-skill",
  "version": "0.2.2",
  "private": true,
  "license": "MIT",
  "type": "module",
  "description": "Deterministic scene-to-SVG engine for the draw-vector-art Codex skill",
  "engines": {
    "node": ">=20.3.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:runtime": "tsc -p tsconfig.runtime.json",
    "check": "npm run build:runtime && npm run build && npm test",
    "benchmark": "node scripts/run-engine.mjs benchmark",
    "doctor": "node scripts/run-engine.mjs doctor",
    "draw": "node scripts/run-engine.mjs",
    "draw:dev": "npm run build --silent && node dist/scripts/cli.js",
    "runtime:prepare": "node scripts/run-engine.mjs prepare",
    "schema": "node scripts/run-engine.mjs schema --out references/scene.schema.json",
    "test": "npm run build --silent && node scripts/run-tests.mjs"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "sharp": "^0.34.3",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0"
  }
}
